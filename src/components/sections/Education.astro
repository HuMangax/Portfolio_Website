---
const courses = [
  "Data Structures & Algorithms",
  "Software Construction",
  "Relational Databases",
  "Machine Learning",
  "Artificial Intelligence",
  "Computer Graphics",
  "Computer Networking",
  "Data Analytics",
]
---

<section id="education">
  <div class="wrap">
    <div class="sec-head reveal">
      <h2>Education</h2>
    </div>

    <div class="edu-card reveal">
      <h3>University of British Columbia</h3>
      <p class="edu-meta">BSc Computer Science · Sep 2022 – May 2028 (expected)</p>
      <h4>Relevant coursework</h4>
      <ul class="course-list">
        {courses.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  section {
    padding: 108px 0;
    background: var(--paper-dim);
  }

  .wrap {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ---- Section heading ---- */
  .sec-head {
    margin-bottom: 52px;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--moss);
    margin-bottom: 14px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    color: var(--pine-deep);
    line-height: 1.15;
  }

  /* ---- Education card ---- */
  .edu-card {
    background: #fff;
    border: 1px solid rgba(45, 51, 48, 0.12);
    border-radius: 18px;
    padding: 32px 34px;
    max-width: 760px;
  }

  .edu-card h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 600;
    font-size: 1.35rem;
    color: var(--pine-deep);
    line-height: 1.3;
  }

  .edu-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--moss);
    margin: 10px 0 24px;
    letter-spacing: 0.04em;
  }

  .edu-card h4 {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--moss);
    margin-bottom: 12px;
  }

  .course-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }

  .course-list li {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--pine);
    background: rgba(159, 179, 163, 0.28);
    padding: 6px 14px;
    border-radius: 99px;
  }

  /* ---- Scroll reveal ---- */
  .reveal {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal.in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ---- Mobile ---- */
  @media (max-width: 640px) {
    section {
      padding: 84px 0;
    }
    .edu-card {
      padding: 26px 22px;
    }
  }
</style>

<script>
  const els = document.querySelectorAll('#education .reveal');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add('in'));
  }
</script>
