---
import ProjectCard from "../ui/ProjectCard.tsx"
import { projects } from "../../data/projects"
---

<section id="projects" class="py-28">
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-mono text-xs tracking-widest uppercase mb-3" style="color: var(--moss)">Projects</p>
    <h2 class="font-serif text-4xl mb-14" style="color: var(--pine-deep)">
      Things I've built — for work and for fun.
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map(project => (
        <ProjectCard client:visible {...project} />
      ))}
    </div>
  </div>
</section>