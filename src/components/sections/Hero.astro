<style>
  header {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: linear-gradient(180deg, #f6f3ea 0%, #edeadd 55%, #dfe2d3 100%);
    overflow: hidden;
  }

  /* ---- Content ---- */
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1080px;
    margin: 0 auto;
    padding: 140px 24px 200px;
    width: 100%;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--moss);
    margin-bottom: 22px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* the little line before the eyebrow text */
  .eyebrow::before {
    content: "";
    width: 34px;
    height: 1px;
    background: var(--moss);
  }

  h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    line-height: 1.06;
    color: var(--pine-deep);
    letter-spacing: -0.01em;
    max-width: 14ch;
  }

  h1 em {
    font-style: italic;
    color: var(--moss);
  }

  .tagline {
    margin-top: 26px;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--ink);
    max-width: 46ch;
    opacity: 0.85;
  }

  .cta-row {
    margin-top: 40px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn-primary, .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
    text-decoration: none;
    padding: 13px 26px;
    border-radius: 99px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .btn-primary {
    background: var(--pine);
    color: var(--paper);
  }

  .btn-primary:hover {
    background: var(--pine-deep);
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -10px rgba(29, 48, 39, 0.55);
  }

  .btn-ghost {
    border: 1.5px solid var(--moss);
    color: var(--pine);
  }

  .btn-ghost:hover {
    background: rgba(159, 179, 163, 0.18);
    transform: translateY(-2px);
  }

  /* ---- Treelines ---- */
  .hero-art {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .trees {
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: auto;
    min-width: 900px;
  }

  /* each layer sways at a different speed */
  .back  { opacity: 0.16; animation: sway 14s ease-in-out infinite alternate; }
  .mid   { opacity: 0.30; animation: sway 11s ease-in-out infinite alternate-reverse; }
  .front { opacity: 0.50; }

  @keyframes sway {
    from { transform: translateX(0) translateY(0); }
    to   { transform: translateX(-28px) translateY(-4px); }
  }

  /* ---- Mist layers ---- */
  .mist {
    position: absolute;
    left: -10%;
    width: 120%;
    height: 160px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(244,241,232,0.9), rgba(244,241,232,0) 70%);
    filter: blur(8px);
  }

  .mist-1 { bottom: 90px; animation: drift 26s linear infinite; }
  .mist-2 { bottom: 30px; opacity: 0.7; animation: drift 34s linear infinite reverse; }

  @keyframes drift {
    from { transform: translateX(-4%); }
    to   { transform: translateX(4%); }
  }

  /* ---- Entry animations ---- */
  .eyebrow, h1, .tagline, .cta-row {
    opacity: 0;
    transform: translateY(18px);
    animation: rise 0.9s cubic-bezier(.22,.8,.32,1) forwards;
  }

  h1       { animation-delay: 0.12s; }
  .tagline { animation-delay: 0.26s; }
  .cta-row { animation-delay: 0.40s; }

  @keyframes rise {
    to { opacity: 1; transform: none; }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .eyebrow, h1, .tagline, .cta-row {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .back  { opacity: 0.35; animation: sway 14s ease-in-out infinite alternate; }
    .mid   { opacity: 0.65; animation: sway 11s ease-in-out infinite alternate-reverse; }
    .front { opacity: 1; }
  }

  /* ---- Mobile ---- */
  @media (max-width: 560px) {
    .hero-inner { padding: 120px 20px 160px; }
  }
</style>